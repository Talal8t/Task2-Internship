  "components": {
    "schemas": {
      "AssignTicketDto": {
        "required": [
          "ticketId",
          "agentId"
        ],
        "type": "object",
        "properties": {
          "ticketId": {
            "type": "string",
            "format": "uuid"
          },
          "agentId": {
            "type": "string"
          }
        }
      },
      "CreateReplyDto": {
        "required": [
          "ticketId",
          "message"
        ],
        "type": "object",
        "properties": {
          "ticketId": {
            "type": "string",
            "format": "uuid"
          },
          "message": {
            "maxLength": 1000,
            "type": "string"
          }
        }
      },
      "CreateTicketDto": {
        "required": [
          "title",
          "description"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 150,
            "type": "string"
          },
          "description": {
            "maxLength": 1000,
            "type": "string"
          }
        }
      },
      "LoginDto": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "RegisterDto": {
        "required": [
          "fullName",
          "email",
          "contactNumber",
          "password"
        ],
        "type": "object",
        "properties": {
          "fullName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "contactNumber": {
            "type": "string"
          },
          "password": {
            "minLength": 6,
            "type": "string"
          }
        }
      },
      "TicketStatus": {
        "type": "integer"
      },
      "UpdateProfileDto": {
        "required": [
          "fullName",
          "contactNumber"
        ],
        "type": "object",
        "properties": {
          "fullName": {
            "maxLength": 100,
            "type": "string"
          },
          "contactNumber": {
            "type": "string"
          }
        }
      },
      "UpdateStatusDto": {
        "required": [
          "ticketId",
          "status"
        ],
        "type": "object",
        "properties": {
          "ticketId": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "$ref": "#/components/schemas/TicketStatus"
          }
        }
      },
      "UpdateTicketDto": {
        "required": [
          "title",
          "description"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 150,
            "type": "string"
          },
          "description": {
            "maxLength": 1000,
            "type": "string"
          }
        }
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "temperatureF": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "summary": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
  },
